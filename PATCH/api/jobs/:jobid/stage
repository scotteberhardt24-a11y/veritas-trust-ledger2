router.patch("/:jobId/stage", auth, async (req, res) => {
  const { stage } = req.body;

  const job = await db.query(
    "SELECT workflow_stage FROM jobs WHERE job_id = $1",
    [req.params.jobId]
  );

  if (!job.rows.length) {
    return res.status(404).json({ error: "Job not found" });
  }

  const current = job.rows[0].workflow_stage;

  if (!canTransition(current, stage)) {
    return res.status(400).json({
      error: `Invalid transition from ${current} to ${stage}`
    });
  }

  await db.query(
    "UPDATE jobs SET workflow_stage = $1 WHERE job_id = $2",
    [stage, req.params.jobId]
  );

  res.json({
    success: true,
    from: current,
    to: stage
  });
});
