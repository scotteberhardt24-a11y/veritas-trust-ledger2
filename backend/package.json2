{
  "name": "veritas-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Veritas Trust Ledger API — Node/Express backend (Railway-ready)",
  "main": "src/server.js",
  "scripts": 
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build step — plain JS'",
    "lint": "eslint src/ --if-present",
    "test": "jest --passWithNoTests",
    "db:migrate": "node src/db/migrate.js",
    "worker:projection": "node src/workers/productionWorker.js",
    "worker:subscriber": "node src/workers/eventSubscriber.js",
    "worker:audit": "node src/workers/audit.js",
    "worker:cobol": "node src/workers/cobolQueue.js"
    "prisma:seed": "tsx prisma/seed.ts"  

  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@aws-sdk/s3-request-presigner": "^3.1049.0",
    "@prisma/client": "6.16.2",
    "ajv": "^8.18.0",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.10",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "ml-distance": "^4.0.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "openai": "^6.38.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^13.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prisma": "6.16.2",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
